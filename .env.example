# Domain configuration
DOMAIN=api.example.com

# Cloudflare API token for DNS challenge
# Generate at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit
CF_DNS_API_TOKEN=your_cloudflare_api_token

# Let's Encrypt email for certificate notifications
ACME_EMAIL=your-email@example.com

# Router-Maestro server API key.
# Leave blank to let the server generate and persist a sk-rm-... key on first start.
# Set a fixed value only when your deployment automation needs one.
ROUTER_MAESTRO_API_KEY=

# Log level (DEBUG, INFO, WARNING, ERROR)
ROUTER_MAESTRO_LOG_LEVEL=INFO

# Enable Responses API bridge for GPT-5 models (1=on, 0=off)
# When enabled, Anthropic/Gemini requests targeting GPT-5 family models
# are routed through Copilot's /responses endpoint instead of /chat/completions.
# ROUTER_MAESTRO_EXPERIMENTAL_RESPONSES_API=1

# Traefik dashboard auth (generate with: htpasswd -nB admin)
# Example: admin:$2y$05$... (user:bcrypt_hash)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$your_bcrypt_hash_here
